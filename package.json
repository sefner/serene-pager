{
  "name": "lan-pager",
  "version": "0.3.6",
  "description": "Peer-to-peer LAN pager for dental operatories (no server required)",
  "main": "main.js",
  "author": "",
  "license": "MIT",
  "scripts": {
    "start": "electron .",
    "dist": "electron-builder --win --x64",
    "release": "electron-builder --win --x64 --publish always"
  },
  "build": {
    "appId": "dental.serene.pager",
    "productName": "Serene Pager",
    "publish": {
      "provider": "github",
      "owner": "sefner",
      "repo": "serene-pager",
      "releaseType": "release"
    },
    "files": [
      "main.js",
      "preload.js",
      "ui/**",
      "assets/**"
    ],
    "extraFiles": [
      {
        "from": "test-launchers",
        "to": "."
      }
    ],
    "win": {
      "target": [
        "zip",
        "nsis"
      ],
      "icon": "assets/icon.png",
      "signAndEditExecutable": false
    },
    "nsis": {
      "oneClick": true,
      "perMachine": false,
      "createDesktopShortcut": true
    }
  },
  "devDependencies": {
    "electron": "^32.0.0",
    "electron-builder": "^24.13.3"
  },
  "dependencies": {
    "electron-updater": "^6.8.9"
  }
}
